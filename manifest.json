{
  "manifest_version": 3,
  "name": "MethodProof",
  "version": "0.1.0",
  "description": "MethodProof assessment telemetry extension",
  "permissions": ["webNavigation", "tabs", "storage", "alarms", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "MethodProof"
  },
  "externally_connectable": {
    "matches": ["*://localhost/*", "*://*.methodproof.com/*"]
  }
}
